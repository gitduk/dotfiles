{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "opusplan",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' '任务完成，请查看结果'",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' '需要你的输入，请切换到终端'",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' '需要你的授权，请切换到终端'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "dev-browser@dev-browser-marketplace": true
  },
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "context7": {
      "command": "bun",
      "args": [
        "x",
        "-y",
        "@context7/mcp-server"
      ],
      "description": "Live documentation lookup"
    }
  },
  "packageManager": "bun",
  "hasCompletedOnboarding": true
}
