{
  "include": [
    "~/.config/waybar/modules.jsonc",
    "~/.config/waybar/custom.jsonc",
    "~/.config/waybar/hyprland.jsonc"
  ],
  "layer": "top",
  "exclusive": true,
  "kpassthrough": false,
  "position": "top",
  "spacing": 3,
  "fixed-center": true,
  "ipc": true,
  "margin-top": 3,
  "margin-left": 8,
  "margin-right": 8,
  "reload_style_on_change": true,

  "modules-left": [
    "hyprland/workspaces#roman",
    "custom/separator#dot-line",
    "cpu",
    "memory",
    "temperature",
    "custom/poetry"
  ],

  "modules-center": [
    "custom/breath",
    "idle_inhibitor",
    "custom/separator#dot-line",
    "clock",
    "group/color"
  ],

  "modules-right": [
    "hyprland/submap",
    "network#speed",
    "custom/easytier",
    "custom/singbox",
    "custom/separator#dot-line",
    "group/audio",
    "backlight",
    "battery"
  ]
}
