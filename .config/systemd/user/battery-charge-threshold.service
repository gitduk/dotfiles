[Unit]
Description=Set Battery Charge Thresholds
After=default.target
ConditionPathExists=/sys/class/power_supply/BAT0

[Service]
Type=oneshot
ExecStart=/usr/bin/sudo /bin/sh -c 'echo 40 > /sys/class/power_supply/BAT0/charge_control_start_threshold'
ExecStart=/usr/bin/sudo /bin/sh -c 'echo 80 > /sys/class/power_supply/BAT0/charge_control_end_threshold'
RemainAfterExit=yes

[Install]
WantedBy=default.target
