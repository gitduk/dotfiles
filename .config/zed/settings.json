{
  "ssh_connections": [
    {
      "host": "max",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/wukaige/axum-project"
          ]
        }
      ]
    }
  ],
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "",
      },
    },
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "languages": {
    "Python": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
      "formatter": {
        "external": {
          "command": "ruff",
          "arguments": ["format", "--stdin-filename", "{buffer_path}", "-"],
        },
      },
      "language_servers": ["basedpyright", "ruff"],
    },
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "basedpyright.analysis.typeCheckingMode": "standard",
      },
    },
  },
  "language_models": {
    "anthropic": {
      "api_url": "http://localhost:8080/anthropic",
    },
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "mcp:mcp-server-sequential-thinking:sequentialthinking": {
          "default": "allow",
        },
        "save_file": {
          "default": "allow",
        },
        "move_path": {
          "default": "allow",
        },
        "terminal": {
          "default": "allow",
        },
      },
    },
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest",
      "enable_thinking": false,
    },
    "commit_message_model": {
      "provider": "anthropic",
      "model": "claude-haiku-4-5-latest",
    },
    "thread_summary_model": {
      "provider": "anthropic",
      "model": "claude-haiku-4-5-latest",
    },
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark Pro",
  },
  "git": {
    "inline_blame": {
      "enabled": true,
    },
  },
  "terminal": {
    "shell": {
      "program": "zsh",
    },
  },
  "autosave": "on_focus_change",
}
