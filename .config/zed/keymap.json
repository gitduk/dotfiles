[
  {
    "bindings": {
      "ctrl-`": null,
      "ctrl-k": null
    }
  },
  {
    "bindings": {
      "alt-enter": "editor::OpenExcerpts",
      "ctrl-enter": "assistant::InlineAssist",
      "ctrl-space": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
      "ctrl-h": "editor::Backspace",
      "ctrl-shift-v": "editor::Paste"
    }
  },
  {
    "context": "Editor && vim_mode == normal && !menu",
    "bindings": {
      "ctrl-h": "vim::StartOfLine",
      "ctrl-enter": "assistant::InlineAssist"
    }
  },
  {
    "context": "((vim_mode == normal || vim_mode == visual) || vim_mode == operator)",
    "bindings": {
      "shift-h": "pane::ActivatePreviousItem",
      "shift-l": "pane::ActivateNextItem"
    }
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-k": ["vim::Literal", ["ctrl-k", "\u000b"]]
    }
  },
  {
    "context": "vim_mode == insert || vim_mode == replace || vim_mode == waiting",
    "unbind": {
      "ctrl-k": ["vim::PushDigraph", {}]
    }
  },
  {
    "context": "Editor && edit_prediction",
    "bindings": {
      "ctrl-f": "editor::AcceptEditPrediction",
      "alt-l": null,
      "alt-tab": null
    }
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "tab": "editor::ComposeCompletion"
    }
  },
  {
    "context": "Editor && (edit_prediction && (showing_completions || in_leading_whitespace))",
    "bindings": {
      "ctrl-f": "editor::AcceptEditPrediction"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "left": "project_panel::CollapseSelectedEntry",
      "right": "project_panel::ExpandSelectedEntry",
      "f2": "project_panel::Rename",
      "enter": "project_panel::Rename",
      "space": "project_panel::Open",
      "backspace": "project_panel::Delete",
      "alt-shift-f": "project_panel::NewSearchInDirectory"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-space": "terminal_panel::Toggle",
      "alt-left": ["terminal::SendText", "\u001bb"],
      "alt-right": ["terminal::SendText", "\u001bf"],
      "up": ["terminal::SendKeystroke", "up"],
      "pageup": ["terminal::SendKeystroke", "pageup"],
      "down": ["terminal::SendKeystroke", "down"],
      "pagedown": ["terminal::SendKeystroke", "pagedown"],
      "escape": ["terminal::SendKeystroke", "escape"],
      "enter": ["terminal::SendKeystroke", "enter"],
      "ctrl-c": ["terminal::SendKeystroke", "ctrl-c"],
      "ctrl-w": ["terminal::SendKeystroke", "ctrl-w"],
      "ctrl-j": ["terminal::SendKeystroke", "ctrl-j"],
      "ctrl-k": ["terminal::SendKeystroke", "ctrl-k"]
    }
  },
  {
    "context": "KeymapEditor",
    "unbind": {
      "ctrl-k": "keymap_editor::OpenCreateKeybindingModal"
    }
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-k": "pane::SplitUp"
    }
  },
  {
    "context": "RecentProjects || RecentProjects > Picker > Editor",
    "unbind": {
      "ctrl-k": "recent_projects::ToggleActionsMenu"
    }
  }
]
