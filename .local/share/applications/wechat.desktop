[Desktop Entry]
Name=wechat
Name[zh_CN]=微信
Exec=env QT_IM_MODULE=fcitx5 GTK_IM_MODULE=fcitx5 'XMODIFIERS=@im=fcitx5' QT_AUTO_SCREEN_SCALE_FACTOR=1 'QT_QPA_PLATFORM=wayland;xcb' 'LD_PRELOAD=/usr/lib/x86_64-linux-gnu/libxkbcommon.so.0.0.0' /usr/bin/wechat --enable-wayland-ime %U
StartupNotify=true
Terminal=false
Icon=/usr/share/icons/hicolor/256x256/apps/wechat.png
Type=Application
Categories=Utility;
Comment=Wechat Desktop
Comment[zh_CN]=微信桌面版

