#!/usr/bin/env bash

show_help() {
  cat <<EOF
Usage: sl [-r] <pattern> [<pattern> ...]

SSH port forwarding wrapper with simplified syntax.

Patterns:
  <host>:<port>[,<port>...]              Forward local port(s) to remote (same port both sides)
  <local_port>:<host>:<remote_port>      Forward local port to different remote port

Options:
  -r    Remote forwarding (default: local forwarding)
  -h    Show this help message

Examples:
  sl wk:8000                # Local forward: localhost:8000 -> wk:8000
  sl wk:4000,4001,4002      # Local forward: ports 4000, 4001, 4002 on wk
  sl 8001:wk:8000           # Local forward: localhost:8001 -> wk:8000
  sl -r wk:8000             # Remote forward: wk:8000 -> localhost:8000
  sl -r wk:4000,4001        # Remote forward: wk:4000, wk:4001 -> localhost
EOF
}

# Build a single -L or -R flag string for one port entry.
# Usage: build_forward_flags <mode> <bind_addr> <local_port> <remote_port>
#   mode:      -NL or -NR
#   bind_addr: "0.0.0.0:" or ""
#   local_port / remote_port: numeric
build_forward_flag() {
  local mode="$1" bind_addr="$2" local_port="$3" remote_port="$4"
  if [[ "$mode" == "-NL" ]]; then
    printf -- "-L %s%s:localhost:%s" "$bind_addr" "$local_port" "$remote_port"
  else
    printf -- "-R %s%s:localhost:%s" "$bind_addr" "$remote_port" "$local_port"
  fi
}

# Print a human-readable line for one port mapping.
print_mapping() {
  local mode="$1" host="$2" local_port="$3" remote_port="$4"
  if [[ "$mode" == "-NL" ]]; then
    printf "\e[32m[L]\e[0m \e[32m:%-6s\e[0m ⇒  \e[34m%s:%-6s\e[0m\n" \
      "$local_port" "$host" "$remote_port" >&2
  else
    printf "\e[34m[R]\e[0m \e[34m%s:%-6s\e[0m ⇒  \e[32m:%-6s\e[0m\n" \
      "$host" "$remote_port" "$local_port" >&2
  fi
}

main() {
  local mode="-NL"
  local bind_addr="0.0.0.0:"
  local host=""
  local -a forward_flags=()
  local -a args=("$@")

  # Handle options
  case "${args[0]}" in
    -h|--help)
      show_help
      return 0
      ;;
    -r)
      mode="-NR"
      bind_addr=""
      args=("${args[@]:1}")
      ;;
  esac

  if [[ ${#args[@]} -eq 0 ]]; then
    echo "Error: Missing argument" >&2
    show_help
    return 1
  fi

  for arg in "${args[@]}"; do
    # Pattern: local_port:host:remote_port  (no comma support here — unambiguous 3-field form)
    if [[ "$arg" =~ ^([0-9]+):([^:,]+):([0-9]+)$ ]]; then
      local local_port="${BASH_REMATCH[1]}"
      host="${BASH_REMATCH[2]}"
      local remote_port="${BASH_REMATCH[3]}"
      print_mapping "$mode" "$host" "$local_port" "$remote_port"
      forward_flags+=("$(build_forward_flag "$mode" "$bind_addr" "$local_port" "$remote_port")")

    # Pattern: host:port[,port,...]
    elif [[ "$arg" =~ ^([^:,]+):([0-9][0-9,]*)$ ]]; then
      host="${BASH_REMATCH[1]}"
      local ports_str="${BASH_REMATCH[2]}"
      IFS=',' read -ra ports <<< "$ports_str"
      for port in "${ports[@]}"; do
        [[ "$port" =~ ^[0-9]+$ ]] || { echo "Error: Invalid port '$port' in '$arg'" >&2; return 1; }
        print_mapping "$mode" "$host" "$port" "$port"
        forward_flags+=("$(build_forward_flag "$mode" "$bind_addr" "$port" "$port")")
      done

    else
      echo "Error: Invalid pattern '$arg'" >&2
      show_help
      return 1
    fi
  done

  # All patterns must target the same host (ssh only accepts one destination)
  # shellcheck disable=SC2086
  ssh -N ${forward_flags[*]} "$host"
}

main "$@"
